generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id           String   @id @default(uuid())
  name         String
  category     String
  city         String
  address      String?
  phone        String?
  whatsapp     String?
  email        String?
  website      String?
  rating       Float?
  reviewsCount Int?
  lat          Float?
  lng          Float?
  photosCount  Int?
  status       String   @default("scraped")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
